DATABASE_URL=postgresql://localhost/commonplace
STORAGE_DIR=../storage/entries

# OCR backend: "local" (PaddleOCR line detection + TrOCR handwriting recognition,
# fully on-device, free, no API key) or "anthropic" (hosted Claude vision — most
# accurate on messy handwriting, per-word confidence + alternates, ~1-2c/page).
OCR_BACKEND=local

# Local backend tuning:
# TROCR_MODEL=microsoft/trocr-base-handwritten   # -small = faster, -large = more accurate
# OCR_MAX_DIM=1568                               # longest edge (px) sent to OCR

# Needed when OCR_BACKEND=anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8
