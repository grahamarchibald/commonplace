DATABASE_URL=postgresql://localhost/commonplace
STORAGE_DIR=../storage/entries

# OCR backend: "ollama" (local, free) or "anthropic" (hosted Claude vision).
# - anthropic: most accurate, seconds/page, per-word confidence + alternates, ~1-2c/page.
# - ollama: free/on-device, but plain-text only (no per-word confidence) and slow on
#   modest hardware. The 3B model fits an 8GB machine; the 7B swap-thrashes there and
#   needs more RAM/GPU.
OCR_BACKEND=ollama

# Used when OCR_BACKEND=ollama:
OLLAMA_MODEL=qwen2.5vl:3b
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_NUM_CTX=4096      # local context window (must fit image + transcript)
# OLLAMA_TIMEOUT=1800      # max seconds per local OCR call

# Needed when OCR_BACKEND=anthropic:
# ANTHROPIC_API_KEY=sk-ant-...

# Longest edge (px) images are downscaled to before OCR. Higher = more accurate but
# slower locally; 1024-1280 is a good local range on 8GB. Default 1568.
# OCR_MAX_DIM=1152
